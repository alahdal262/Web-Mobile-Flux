# ═══════════════════════════════════════════════════════════════
# Mobile-WP Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Backend API Server ───────────────────────────────────────
# Port the Express API listens on
API_PORT=3001

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local development example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobilewp

# Production example (shared Postgres with other services):
# DATABASE_URL=postgresql://orchestrator:YOUR_PASSWORD@localhost:5432/fluxbuilder

# Node environment: development | production
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Session secret for cookie signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change_this_to_a_random_64_char_hex_string

# ── Frontend Builder ─────────────────────────────────────────
# Port the Vite dev server listens on
PORT=5173

# Base path for the app (e.g., / or /app)
BASE_PATH=/

# ── Optional: Shared Services ────────────────────────────────
# Redis (for session store, caching, queue)
# REDIS_URL=redis://localhost:6379

# S3-compatible storage (for user uploads, build artifacts)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=mobilewp-assets
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key

# ── Optional: WordPress Plugin Testing ───────────────────────
# Webhook URL the plugin sends events to
# WEBHOOK_URL=http://localhost:3001/webhooks/wordpress

# ── Optional: CORS ───────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,https://yoursite.com
